# Server
PORT=5001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/webrezervasyon

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Google Sign-In — Web OAuth Client ID (same string as NEXT_PUBLIC_GOOGLE_CLIENT_ID on the frontend)
# Copy this file to .env and set real values. Do not commit .env.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ImageKit (client uploads — same public key & URL endpoint as frontend NEXT_PUBLIC_*)
IMAGEKIT_PUBLIC_KEY=your_public_key
IMAGEKIT_PRIVATE_KEY=your_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id/

# Trial subscription length (days) when a new business is created
BUSINESS_TRIAL_DAYS=90

# Dev only: allow creating reservations even if the business has no active subscription
# ALLOW_RESERVATIONS_WITHOUT_SUBSCRIPTION=true

# --- Stripe (abonelik Checkout + webhook) ---
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_xxx
# Her paket = Stripe’da ayrı recurring Price ID (price_...). Tek sk/pk tüm fiyatlar için yeterli.
STRIPE_PRICE_ID=price_xxx
STRIPE_PRICE_LABEL=Standart
# İkinci paket (opsiyonel):
STRIPE_PRICE_ID_2=price_yyy
STRIPE_PRICE_LABEL_2=Pro
# Eski/tek isim: STRIPE_PRICE_ID_MONTHLY=price_xxx ve STRIPE_PRICE_LABEL_MONTHLY=...
# Üçüncü paket (opsiyonel): STRIPE_PRICE_ID_3 + STRIPE_PRICE_LABEL_3
# Webhook signing secret (Dashboard webhook endpoint veya: stripe listen --forward-to ...)
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Ödeme sonrası yönlendirme (Next.js ön yüz)
FRONTEND_URL=http://localhost:3000
# Opsiyonel: Elements / ileride; Checkout redirect için zorunlu değil
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
