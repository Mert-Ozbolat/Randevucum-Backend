# Server
PORT=5001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/webrezervasyon

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Google Sign-In — Web OAuth Client ID (same string as NEXT_PUBLIC_GOOGLE_CLIENT_ID on the frontend)
# Copy this file to .env and set real values. Do not commit .env.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ImageKit (client uploads — same public key & URL endpoint as frontend NEXT_PUBLIC_*)
IMAGEKIT_PUBLIC_KEY=your_public_key
IMAGEKIT_PRIVATE_KEY=your_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id/

# Trial subscription length (days) when a new business is created
BUSINESS_TRIAL_DAYS=90

# Dev only: allow creating reservations even if the business has no active subscription
# ALLOW_RESERVATIONS_WITHOUT_SUBSCRIPTION=true

# --- Stripe (abonelik Checkout + webhook) ---
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_xxx
# Her paket = Stripe’da ayrı recurring Price ID (price_...). Tek sk/pk tüm fiyatlar için yeterli.
STRIPE_PRICE_ID=price_xxx
STRIPE_PRICE_LABEL=Standart
# İkinci paket (opsiyonel):
STRIPE_PRICE_ID_2=price_yyy
STRIPE_PRICE_LABEL_2=Pro
# Eski/tek isim: STRIPE_PRICE_ID_MONTHLY=price_xxx ve STRIPE_PRICE_LABEL_MONTHLY=...
# Üçüncü paket (opsiyonel): STRIPE_PRICE_ID_3 + STRIPE_PRICE_LABEL_3
# Webhook signing secret (Dashboard webhook endpoint veya: stripe listen --forward-to ...)
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Ödeme sonrası yönlendirme (Next.js ön yüz)
FRONTEND_URL=http://localhost:3000
# Opsiyonel: Elements / ileride; Checkout redirect için zorunlu değil
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- WhatsApp reminders (PRO only) — Twilio WhatsApp (default) ---
# true: send real messages. false/missing: dry-run (log only, no API calls).
WHATSAPP_ENABLED=false
# twilio (default) | meta — Twilio için aşağıdaki TWILIO_* değişkenleri zorunludur.
WHATSAPP_PROVIDER=twilio
# Reminder time: send X minutes before appointment, scanning a small window to avoid misses.
WHATSAPP_REMINDER_MINUTES_BEFORE=60
WHATSAPP_REMINDER_WINDOW_MINUTES=10
# Business timezone offset in minutes (Europe/Istanbul = UTC+3 => 180)
BUSINESS_TZ_OFFSET_MINUTES=180

# Twilio WhatsApp (primary) — Console → Account; Messaging → WhatsApp sandbox or approved sender
# TWILIO_WHATSAPP_FROM format: whatsapp:+E164 (ör. whatsapp:+14155238886)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Meta WhatsApp Cloud API (only if WHATSAPP_PROVIDER=meta)
# https://developers.facebook.com/docs/whatsapp/cloud-api
# WHATSAPP_CLOUD_TOKEN=EAA...
# WHATSAPP_PHONE_NUMBER_ID=123456789012345
# WHATSAPP_GRAPH_VERSION=v21.0

# Pro gating: set which Stripe price ids are considered PRO
# (comma-separated; if omitted, STRIPE_PRICE_ID_2 is treated as pro by convention)
STRIPE_PRO_PRICE_IDS=price_pro_monthly,price_pro_yearly

# Job trigger secret (use Cloud Scheduler to call /jobs/whatsapp-reminders)
JOBS_SECRET=change_me
