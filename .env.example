# Server
PORT=5001
NODE_ENV=development

# --- Security ---
# Production: https://randevucum.online,https://www.randevucum.online (virgülle ayırın)
CORS_ORIGINS=http://localhost:3000
# FRONTEND_URL tek adres için yeterli (CORS_ORIGINS yoksa kullanılır)
FRONTEND_URL=http://localhost:3000
# Rate limit (15 dk pencerede max istek)
RATE_LIMIT_MAX=400
AUTH_RATE_LIMIT_MAX=25
JSON_BODY_LIMIT=256kb
TRUST_PROXY_HOPS=1

# MongoDB
MONGODB_URI=mongodb://localhost:27017/webrezervasyon

# JWT (production: en az 32 karakter rastgele — openssl rand -base64 48)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# Google Sign-In — Web OAuth Client ID (same string as NEXT_PUBLIC_GOOGLE_CLIENT_ID on the frontend)
# Copy this file to .env and set real values. Do not commit .env.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ImageKit (client uploads — same public key & URL endpoint as frontend NEXT_PUBLIC_*)
IMAGEKIT_PUBLIC_KEY=your_public_key
IMAGEKIT_PRIVATE_KEY=your_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id/

# Ücretsiz PRO deneme süresi (gün) — yeni işletme oluşturulunca
BUSINESS_TRIAL_DAYS=30
# Ödeme başarısız sonrası grace (gün) — PRO erişim devam eder
SUBSCRIPTION_GRACE_DAYS=7
# Abonelik süresi / grace kontrol cron aralığı (ms). 3600000 = 1 saat
SUBSCRIPTION_BILLING_CRON_MS=3600000
ENABLE_SUBSCRIPTION_BILLING_CRON=true

# Dev only: allow creating reservations even if the business has no active subscription
# ALLOW_RESERVATIONS_WITHOUT_SUBSCRIPTION=true

# --- Stripe (abonelik Checkout + webhook) ---
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_xxx
# Her paket = Stripe’da ayrı recurring Price ID (price_...). Tek sk/pk tüm fiyatlar için yeterli.
STRIPE_PRICE_ID=price_xxx
STRIPE_PRICE_LABEL=Standart
# İkinci paket (opsiyonel):
STRIPE_PRICE_ID_2=price_yyy
STRIPE_PRICE_LABEL_2=Pro
# Fiyat listesi / Checkout: yukarıdaki price_... veya prod_... ID’lerinden Stripe API ile otomatik çekilir.
# prod_ kullanıyorsanız ürünün varsayılan (default) recurring fiyatı kullanılır.
# Eski/tek isim: STRIPE_PRICE_ID_MONTHLY=price_xxx ve STRIPE_PRICE_LABEL_MONTHLY=...
# Üçüncü paket (opsiyonel): STRIPE_PRICE_ID_3 + STRIPE_PRICE_LABEL_3
# Webhook signing secret (Dashboard webhook endpoint veya: stripe listen --forward-to ...)
# Stripe Dashboard’da şu event’leri ekleyin:
# checkout.session.completed, customer.subscription.created|updated|deleted,
# invoice.payment_failed, invoice.paid
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Ödeme sonrası yönlendirme (Next.js ön yüz)
FRONTEND_URL=http://localhost:3000
# Opsiyonel: Elements / ileride; Checkout redirect için zorunlu değil
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- WhatsApp (UltraMsg varsayılan) ---
# Yeni randevu: işletme sahibine anlık bildirim (randevu kaydı oluşur oluşmaz, PRO gerekmez).
# Müşteriye randevu onay mesajı: PRO işletmeler. Hatırlatmalar: PRO + cron/job.
# true: send real messages. false/missing: dry-run (log only, no API calls).
WHATSAPP_ENABLED=false
# ultramsg (default) | meta
WHATSAPP_PROVIDER=ultramsg
# Randevuya kalan süre: başlangıcı şimdi ile (şimdi + N dakika) arasındaysa WhatsApp hatırlatması (daha önce gönderilmediyse).
WHATSAPP_REMINDER_LOOKAHEAD_MINUTES=60
# Eski isim (geriye dönük): WHATSAPP_REMINDER_MINUTES_BEFORE — yalnızca LOOKAHEAD yoksa kullanılır.
# Sunucu açıkken job’u periyodik çalıştır (varsayılan: true). Kapatmak için: ENABLE_REMINDER_CRON=false
ENABLE_REMINDER_CRON=true
# Kontrol aralığı (ms). 300000 = 5 dakika.
REMINDER_CRON_EVERY_MS=300000
# Business timezone offset in minutes (Europe/Istanbul = UTC+3 => 180)
BUSINESS_TZ_OFFSET_MINUTES=180

# UltraMsg — https://ultramsg.com → Instance ID + Token (panelden kopyalayın)
# Instance QR ile bağlı olmalı; değilse mesaj kuyruğa alınır, bağlanınca gider.
ULTRAMSG_INSTANCE_ID=instanceXXXX
ULTRAMSG_TOKEN=
# Öncelik: 0=OTP/acil, 5=genel (varsayılan), 10=promosyon
ULTRAMSG_PRIORITY=5
# Opsiyonel: gönderim referenceId öneki (log/izleme)
# ULTRAMSG_REFERENCE_PREFIX=randevucum
#
# RSVP (geliyor musunuz?) için UltraMsg webhook:
# UltraMsg panelde "Webhook on Received" açın ve URL’yi şu endpoint’e verin:
#   https://YOUR_API_DOMAIN/whatsapp/webhook/ultramsg?token=ULTRAMSG_WEBHOOK_SECRET
ULTRAMSG_WEBHOOK_SECRET=change-me

# Meta WhatsApp Cloud API (only if WHATSAPP_PROVIDER=meta)
# https://developers.facebook.com/docs/whatsapp/cloud-api
# WHATSAPP_CLOUD_TOKEN=EAA...
# WHATSAPP_PHONE_NUMBER_ID=123456789012345
# WHATSAPP_GRAPH_VERSION=v21.0

# Pro gating (müşteri hatırlatması / müşteri randevu mesajı): Stripe Price ID (price_...).
# STRIPE_PRICE_ID_2 prod_... ise yok sayılır — Dashboard’dan Pro paketin price_... ID’sini yazın.
STRIPE_PRO_PRICE_IDS=price_xxx_pro_monthly,price_xxx_pro_yearly

# Job trigger secret — production zorunlu (Cloud Scheduler: x-jobs-secret header)
# openssl rand -hex 32
JOBS_SECRET=change_me_to_long_random_secret
